<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Flowspace — Project Suite v2</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/react@18.2.0/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18.2.0/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/prop-types@15.8.1/prop-types.min.js"></script>
  <script>if(window.React&&!window.React.PropTypes)window.React.PropTypes=window.PropTypes;</script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { margin: 0; background: #F7F8FC; }
    @keyframes fadeSlide { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
    ::-webkit-scrollbar { height: 6px; width: 6px; }
    ::-webkit-scrollbar-thumb { background: #D8DBE3; border-radius: 8px; }
    .dark-mode { background: #0E0F14; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useRef, useEffect } = React;

    /* ── ICONS (inline SVG to avoid CDN dependency issues) ──────────── */
    const Icon = ({ name, size = 18, strokeWidth = 2, className = "" }) => {
      const ref = useRef(null);
      useEffect(() => {
        if (window.lucide && ref.current) {
          ref.current.innerHTML = '';
          const i = document.createElement('i');
          i.setAttribute('data-lucide', name.replace(/([a-z])([A-Z])/g, '$1-$2').toLowerCase());
          ref.current.appendChild(i);
          window.lucide.createIcons({ attrs: { width: size, height: size, class: className, 'stroke-width': strokeWidth } });
        }
      }, [name, size, strokeWidth, className]);
      return <span ref={ref} className="inline-flex items-center justify-center leading-none"></span>;
    };

    /* ── DATA ───────────────────────────────────────────────────────── */
    const NAV_ITEMS = [
      { key: "dashboard", label: "Dashboard", icon: "layout-dashboard" },
      { key: "projetos", label: "Projetos", icon: "folder-kanban" },
      { key: "boards", label: "Boards", icon: "table-2" },
      { key: "kanban", label: "Kanban", icon: "trello" },
      { key: "cronograma", label: "Cronograma", icon: "calendar-clock" },
      { key: "calendario", label: "Calendário", icon: "calendar-days" },
      { key: "clientes", label: "Clientes", icon: "user-square-2" },
      { key: "configuracoes", label: "Configurações", icon: "settings" },
    ];

    const KPI = [
      { label: "Projetos", value: "24", sub: "+3 este mês", color: "#3B82F6", icon: "folder-kanban" },
      { label: "Tarefas", value: "312", sub: "18 novas hoje", color: "#7C3AED", icon: "check-circle-2" },
      { label: "Em andamento", value: "87", sub: "62% do total", color: "#F59E0B", icon: "clock" },
      { label: "Concluídas", value: "196", sub: "+12 esta semana", color: "#22C55E", icon: "check-circle-2" },
      { label: "Horas", value: "1.284h", sub: "média 6.4h/dia", color: "#3B82F6", icon: "clock" },
      { label: "Clientes", value: "38", sub: "5 ativos agora", color: "#EF4444", icon: "user-square-2" },
    ];

    const STATUS_STYLES = {
      "Done": { bg: "#DCFCE7", text: "#15803D", dot: "#22C55E" },
      "Working On It": { bg: "#FEF3C7", text: "#B45309", dot: "#F59E0B" },
      "Stuck": { bg: "#FEE2E2", text: "#B91C1C", dot: "#EF4444" },
      "Waiting": { bg: "#F3F4F6", text: "#4B5563", dot: "#9CA3AF" },
      "Review": { bg: "#DBEAFE", text: "#1D4ED8", dot: "#3B82F6" },
      "Planning": { bg: "#EDE9FE", text: "#6D28D9", dot: "#7C3AED" },
    };
    const STATUS_LIST = Object.keys(STATUS_STYLES);

    const PEOPLE = [
      { name: "Ana Souza", color: "#3B82F6", initials: "AS" },
      { name: "Bruno Lima", color: "#7C3AED", initials: "BL" },
      { name: "Carla Dias", color: "#F59E0B", initials: "CD" },
      { name: "Diego Alves", color: "#22C55E", initials: "DA" },
      { name: "Elis Nunes", color: "#EF4444", initials: "EN" },
    ];

    const initialRows = [
      { id: 1, name: "Redesign do site institucional", owners: [0, 1], status: "Working On It", start: 20, len: 30, date: "12 Jul", priority: 3, tags: ["Design", "Web"], progress: 62, comments: 8, files: 4 },
      { id: 2, name: "App mobile - módulo financeiro", owners: [2], status: "Stuck", start: 10, len: 20, date: "05 Jul", priority: 4, tags: ["Mobile"], progress: 24, comments: 3, files: 1 },
      { id: 3, name: "Migração de infraestrutura AWS", owners: [3, 4], status: "Planning", start: 40, len: 25, date: "22 Jul", priority: 2, tags: ["DevOps", "Infra"], progress: 8, comments: 1, files: 0 },
      { id: 4, name: "Campanha de marketing Q3", owners: [1], status: "Review", start: 5, len: 35, date: "01 Jul", priority: 3, tags: ["Marketing"], progress: 85, comments: 15, files: 9 },
      { id: 5, name: "Integração API de pagamentos", owners: [0, 3], status: "Done", start: 0, len: 40, date: "28 Jun", priority: 5, tags: ["Backend", "API"], progress: 100, comments: 22, files: 6 },
      { id: 6, name: "Onboarding de novos clientes", owners: [2, 4], status: "Waiting", start: 55, len: 15, date: "30 Jul", priority: 1, tags: ["CS"], progress: 0, comments: 0, files: 2 },
    ];

    const KANBAN_COLUMNS = [
      { key: "backlog", label: "Backlog", color: "#9CA3AF" },
      { key: "todo", label: "To Do", color: "#3B82F6" },
      { key: "doing", label: "Doing", color: "#F59E0B" },
      { key: "review", label: "Review", color: "#7C3AED" },
      { key: "done", label: "Done", color: "#22C55E" },
    ];

    const initialCards = [
      { id: "c1", col: "backlog", title: "Definir identidade visual v2", desc: "Levantar referências e paleta para o novo branding.", owners: [1], checklist: [3, 5], comments: 2, files: 1, time: "2h 10m", date: "18 Jul" },
      { id: "c2", col: "backlog", title: "Pesquisa com usuários", desc: "Entrevistas com 8 clientes ativos.", owners: [0, 2], checklist: [0, 4], comments: 0, files: 0, time: "0h", date: "20 Jul" },
      { id: "c3", col: "todo", title: "Wireframes do dashboard", desc: "Baixa fidelidade, foco em hierarquia.", owners: [3], checklist: [2, 2], comments: 4, files: 3, time: "1h 40m", date: "15 Jul" },
      { id: "c4", col: "todo", title: "Configurar ambiente de staging", desc: "Docker + pipeline de deploy automático.", owners: [4], checklist: [1, 3], comments: 1, files: 0, time: "3h", date: "16 Jul" },
      { id: "c5", col: "doing", title: "Tela de login e autenticação", desc: "Incluir 2FA e login social.", owners: [0], checklist: [4, 6], comments: 6, files: 2, time: "5h 25m", date: "13 Jul" },
      { id: "c6", col: "doing", title: "Componente de tabela virtualizada", desc: "Suporte a 10k+ linhas sem travar.", owners: [3, 1], checklist: [2, 5], comments: 3, files: 1, time: "4h 05m", date: "14 Jul" },
      { id: "c7", col: "review", title: "Revisão de acessibilidade", desc: "Contraste, foco de teclado, ARIA labels.", owners: [2], checklist: [5, 5], comments: 9, files: 0, time: "1h 15m", date: "10 Jul" },
      { id: "c8", col: "done", title: "Setup do design system", desc: "Tokens de cor, tipografia e espaçamento.", owners: [1, 4], checklist: [6, 6], comments: 12, files: 5, time: "8h 30m", date: "01 Jul" },
    ];

    /* ── UI PRIMITIVES ──────────────────────────────────────────────── */
    function Avatar({ person, size = 28 }) {
      return (
        <div title={person.name}
          className="rounded-full flex items-center justify-center text-white font-medium ring-2 ring-white shrink-0 select-none"
          style={{ width: size, height: size, background: person.color, fontSize: size * 0.38 }}>
          {person.initials}
        </div>
      );
    }

    function AvatarStack({ ids }) {
      return (
        <div className="flex items-center -space-x-2">
          {ids.map((i) => <Avatar key={i} person={PEOPLE[i]} />)}
        </div>
      );
    }

    function StatusPill({ status, onChange }) {
      const [open, setOpen] = useState(false);
      const s = STATUS_STYLES[status];
      return (
        <div className="relative">
          <button onClick={() => setOpen(o => !o)}
            className="px-3.5 py-1.5 rounded-full text-[13px] font-semibold flex items-center gap-1.5 transition-all duration-150 hover:brightness-95"
            style={{ background: s.bg, color: s.text }}>
            {status} <Icon name="chevron-down" size={13} strokeWidth={2.5} />
          </button>
          {open && <>
            <div className="fixed inset-0 z-10" onClick={() => setOpen(false)} />
            <div className="absolute z-20 mt-1.5 w-44 bg-white rounded-xl shadow-lg border border-gray-100 p-1.5" style={{ animation: 'fadeSlide .15s ease' }}>
              {STATUS_LIST.map(opt => (
                <button key={opt} onClick={() => { onChange(opt); setOpen(false); }}
                  className="w-full text-left px-2.5 py-1.5 rounded-lg text-[13px] font-medium flex items-center gap-2 hover:bg-gray-50 transition-colors">
                  <span className="w-2 h-2 rounded-full" style={{ background: STATUS_STYLES[opt].dot }} />
                  {opt}
                </button>
              ))}
            </div>
          </>}
        </div>
      );
    }

    function PriorityStars({ level }) {
      return (
        <div className="flex items-center gap-0.5">
          {[1,2,3,4,5].map(n => (
            <svg key={n} width="14" height="14" viewBox="0 0 24 24" fill={n <= level ? "#F59E0B" : "#E5E7EB"} stroke="none">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>
      );
    }

    function TimelineBar({ start, len }) {
      const color = len + start > 90 ? "#22C55E" : len > 30 ? "#3B82F6" : "#F59E0B";
      return (
        <div className="relative w-40 h-2.5 bg-gray-100 rounded-full overflow-hidden">
          <div className="absolute top-0 h-full rounded-full transition-all" style={{ left: `${start}%`, width: `${len}%`, background: color }} />
        </div>
      );
    }

    function ProgressBar({ value }) {
      const color = value === 100 ? "#22C55E" : value > 50 ? "#3B82F6" : "#F59E0B";
      return (
        <div className="flex items-center gap-2 w-28">
          <div className="flex-1 h-2 bg-gray-100 rounded-full overflow-hidden">
            <div className="h-full rounded-full transition-all" style={{ width: `${value}%`, background: color }} />
          </div>
          <span className="text-[11px] font-medium text-gray-500 w-8 text-right">{value}%</span>
        </div>
      );
    }

    function Tag({ children }) {
      return <span className="px-2 py-0.5 rounded-md bg-gray-100 text-gray-600 text-[11px] font-medium">{children}</span>;
    }

    /* ── SIDEBAR ────────────────────────────────────────────────────── */
    function Sidebar({ active, setActive, dark, activeCount = 0, donePct = 0 }) {
      return (
        <aside className="fixed left-0 top-0 h-screen w-[250px] flex flex-col border-r z-30"
          style={{ background: dark ? "#15171F" : "#FFFFFF", borderColor: dark ? "#22242E" : "#EEF0F5" }}>
          <div className="h-16 flex items-center gap-2.5 px-6">
            <div className="w-8 h-8 rounded-[10px] bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm">F</div>
            <span className={`font-semibold text-[15px] tracking-tight ${dark ? "text-white" : "text-gray-900"}`}>Flowspace</span>
          </div>
          <nav className="flex-1 px-3 mt-3 space-y-0.5 overflow-y-auto">
            {NAV_ITEMS.map(item => {
              const isActive = active === item.key;
              return (
                <button key={item.key} onClick={() => setActive(item.key)}
                  className="w-full flex items-center gap-3 px-3 py-2.5 rounded-[10px] text-[13.5px] font-medium transition-all duration-150"
                  style={{
                    background: isActive ? (dark ? "rgba(59,130,246,0.16)" : "#EFF4FF") : "transparent",
                    color: isActive ? "#3B82F6" : dark ? "#9CA3AF" : "#4B5563",
                  }}
                  onMouseEnter={e => { if (!isActive) e.currentTarget.style.background = dark ? "#1C1E27" : "#F7F8FC"; }}
                  onMouseLeave={e => { if (!isActive) e.currentTarget.style.background = "transparent"; }}>
                  <Icon name={item.icon} size={17} strokeWidth={2} />
                  {item.label}
                </button>
              );
            })}
          </nav>
          <div className={`m-3 p-3.5 rounded-2xl ${dark ? "bg-gray-800/50" : "bg-gray-50"}`}>
            <p className={`text-[12px] font-semibold ${dark ? "text-white" : "text-gray-900"}`}>{donePct}% do Projeto</p>
            <p className="text-[11px] text-gray-500 mt-0.5">{activeCount} atividades em andamento</p>
            <div className="h-1.5 bg-gray-200 rounded-full mt-2 overflow-hidden">
              <div className="h-full rounded-full transition-all" style={{ width: `${donePct}%`, background: donePct >= 80 ? "#22C55E" : donePct >= 40 ? "#3B82F6" : "#F59E0B" }} />
            </div>
          </div>
        </aside>
      );
    }

    /* ── HEADER ─────────────────────────────────────────────────────── */
    function Header({ dark, setDark, crumbs }) {
      const [notifOpen, setNotifOpen] = useState(false);
      return (
        <header className="fixed top-0 right-0 left-[250px] h-16 flex items-center justify-between px-8 z-20 backdrop-blur-sm border-b"
          style={{ background: dark ? "rgba(21,23,31,0.85)" : "rgba(255,255,255,0.85)", borderColor: dark ? "#22242E" : "#EEF0F5" }}>
          <div className="flex items-center gap-1.5 text-[13px]">
            {crumbs.map((c, i) => (
              <React.Fragment key={c}>
                {i > 0 && <Icon name="chevron-right" size={13} className="text-gray-400" />}
                <span className={i === crumbs.length - 1 ? (dark ? "text-white font-semibold" : "text-gray-900 font-semibold") : "text-gray-400"}>{c}</span>
              </React.Fragment>
            ))}
          </div>
          <div className="flex items-center gap-3">
            <div className="relative">
              <Icon name="search" size={15} className="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400" />
              <input placeholder="Pesquisar projetos, tarefas, clientes..."
                className="pl-10 pr-4 py-2 w-72 rounded-full text-[13px] outline-none transition-all focus:w-80"
                style={{ background: dark ? "#1C1E27" : "#F3F4F6", color: dark ? "#E5E7EB" : "#222" }} />
            </div>
            <button className="flex items-center gap-1.5 px-4 py-2 rounded-full bg-blue-500 text-white text-[13px] font-semibold hover:bg-blue-600 transition-all active:scale-[0.97] shadow-[0_4px_14px_rgba(59,130,246,0.35)]">
              <Icon name="plus" size={15} strokeWidth={2.5} /> Novo Projeto
            </button>
            <button onClick={() => setDark(!dark)}
              className={`w-9 h-9 rounded-full flex items-center justify-center transition-colors ${dark ? "bg-gray-800 text-yellow-500" : "bg-gray-100 text-gray-600"}`}>
              <Icon name={dark ? "sun" : "moon"} size={16} />
            </button>
            <div className="relative">
              <button onClick={() => setNotifOpen(o => !o)}
                className={`w-9 h-9 rounded-full flex items-center justify-center relative transition-colors ${dark ? "bg-gray-800 text-gray-400" : "bg-gray-100 text-gray-600"}`}>
                <Icon name="bell" size={16} />
                <span className="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-red-500 ring-2 ring-white" />
              </button>
              {notifOpen && <>
                <div className="fixed inset-0 z-10" onClick={() => setNotifOpen(false)} />
                <div className="absolute right-0 mt-2 w-80 bg-white rounded-2xl shadow-xl border border-gray-100 z-20 overflow-hidden" style={{ animation: 'fadeSlide .15s ease' }}>
                  <div className="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
                    <span className="font-semibold text-[13.5px] text-gray-900">Notificações</span>
                    <span className="text-[11px] text-blue-500 font-medium">3 não lidas</span>
                  </div>
                  {[{ who: "Ana Souza", what: "comentou em Redesign do site", when: "há 5 min" },
                    { who: "Bruno Lima", what: "moveu App mobile para Review", when: "há 32 min" },
                    { who: "Sistema", what: "Prazo de Campanha Q3 vence amanhã", when: "há 2h" }].map((n, i) => (
                    <div key={i} className="px-4 py-3 flex gap-3 hover:bg-gray-50 transition-colors cursor-pointer">
                      <div className="w-2 h-2 rounded-full bg-blue-500 mt-1.5 shrink-0" />
                      <div className="min-w-0">
                        <p className="text-[12.5px] text-gray-900 leading-snug"><span className="font-semibold">{n.who}</span> {n.what}</p>
                        <p className="text-[11px] text-gray-400 mt-0.5">{n.when}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </>}
            </div>
            <Avatar person={PEOPLE[0]} size={34} />
          </div>
        </header>
      );
    }

    /* ── DASHBOARD ──────────────────────────────────────────────────── */
    function Dashboard({ dark }) {
      return (
        <div className="grid grid-cols-3 gap-5">
          {KPI.map(k => (
            <div key={k.label} className="relative rounded-2xl p-5 flex items-center gap-4 overflow-hidden transition-shadow hover:shadow-lg"
              style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
              <span className="absolute left-0 top-0 h-full w-1.5 rounded-l-2xl" style={{ background: k.color }} />
              <div className="w-11 h-11 rounded-[12px] flex items-center justify-center shrink-0" style={{ background: `${k.color}1A`, color: k.color }}>
                <Icon name={k.icon} size={20} />
              </div>
              <div className="min-w-0">
                <p className={`text-[22px] font-bold leading-none ${dark ? "text-white" : "text-gray-900"}`}>{k.value}</p>
                <p className="text-[12.5px] text-gray-500 mt-1.5 font-medium">{k.label}</p>
                <p className="text-[11px] text-gray-400 mt-0.5">{k.sub}</p>
              </div>
            </div>
          ))}
          <div className="col-span-2 rounded-2xl p-6" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
            <div className="flex items-center justify-between mb-5">
              <h3 className={`font-semibold text-[15px] ${dark ? "text-white" : "text-gray-900"}`}>Progresso dos projetos</h3>
              <button className="text-[12px] text-gray-500 flex items-center gap-1"><Icon name="filter" size={13} /> Filtrar</button>
            </div>
            <div className="flex items-end gap-4 h-44">
              {[62, 84, 45, 90, 30, 70, 55, 95, 40, 78].map((v, i) => (
                <div key={i} className="flex-1 rounded-t-lg transition-all hover:opacity-80" style={{ height: `${v}%`, background: i % 3 === 0 ? "#3B82F6" : i % 3 === 1 ? "#7C3AED" : "#22C55E" }} />
              ))}
            </div>
          </div>
          <div className="rounded-2xl p-6" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
            <h3 className={`font-semibold text-[15px] mb-5 ${dark ? "text-white" : "text-gray-900"}`}>Status geral</h3>
            <div className="space-y-3.5">
              {[{ l: "Concluídas", v: 63, c: "#22C55E" }, { l: "Em andamento", v: 28, c: "#F59E0B" }, { l: "Atrasadas", v: 9, c: "#EF4444" }].map(s => (
                <div key={s.l}>
                  <div className="flex justify-between text-[12px] mb-1.5">
                    <span className="text-gray-500 font-medium">{s.l}</span>
                    <span className="font-semibold" style={{ color: s.c }}>{s.v}%</span>
                  </div>
                  <div className="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div className="h-full rounded-full" style={{ width: `${s.v}%`, background: s.c }} />
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      );
    }

    /* ── BOARDS (Monday-style table) ────────────────────────────────── */
    function Boards({ dark }) {
      const [rows, setRows] = useState(initialRows);
      const updateStatus = (id, status) => setRows(r => r.map(row => row.id === id ? { ...row, status } : row));
      const cols = ["Nome", "Responsável", "Status", "Timeline", "Data", "Prioridade", "Tags", "Progresso", "Comentários", "Arquivos"];
      return (
        <div className="rounded-2xl overflow-hidden" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
          <div className="flex items-center justify-between px-6 py-4 border-b" style={{ borderColor: dark ? "#22242E" : "#F0F1F5" }}>
            <div className="flex items-center gap-2.5">
              <span className="w-2.5 h-2.5 rounded-full bg-blue-500" />
              <h3 className={`font-semibold text-[15px] ${dark ? "text-white" : "text-gray-900"}`}>Board — Lançamento Q3</h3>
            </div>
            <button className="text-[12.5px] text-blue-500 font-medium flex items-center gap-1 hover:underline"><Icon name="plus" size={14} /> Adicionar item</button>
          </div>
          <div className="overflow-x-auto">
            <table className="w-full border-collapse">
              <thead>
                <tr style={{ background: dark ? "#15171F" : "#FAFBFD" }}>
                  {cols.map(c => <th key={c} className="text-left px-4 py-3 text-[11.5px] font-semibold text-gray-400 uppercase tracking-wide whitespace-nowrap">{c}</th>)}
                </tr>
              </thead>
              <tbody>
                {rows.map(row => (
                  <tr key={row.id} className="group border-t transition-colors" style={{ borderColor: dark ? "#22242E" : "#F3F4F7" }}
                    onMouseEnter={e => e.currentTarget.style.background = dark ? "#1F212C" : "#FAFBFD"}
                    onMouseLeave={e => e.currentTarget.style.background = "transparent"}>
                    <td className="px-4 py-4 min-w-[220px]"><span className={`text-[13.5px] font-medium ${dark ? "text-white" : "text-gray-900"}`}>{row.name}</span></td>
                    <td className="px-4 py-4"><AvatarStack ids={row.owners} /></td>
                    <td className="px-4 py-4"><StatusPill status={row.status} onChange={s => updateStatus(row.id, s)} /></td>
                    <td className="px-4 py-4"><TimelineBar start={row.start} len={row.len} /></td>
                    <td className="px-4 py-4 text-[12.5px] text-gray-500 whitespace-nowrap">{row.date}</td>
                    <td className="px-4 py-4"><PriorityStars level={row.priority} /></td>
                    <td className="px-4 py-4"><div className="flex gap-1.5 flex-wrap max-w-[140px]">{row.tags.map(t => <Tag key={t}>{t}</Tag>)}</div></td>
                    <td className="px-4 py-4"><ProgressBar value={row.progress} /></td>
                    <td className="px-4 py-4"><span className="flex items-center gap-1.5 text-[12.5px] text-gray-500"><Icon name="message-square" size={13} />{row.comments}</span></td>
                    <td className="px-4 py-4"><span className="flex items-center gap-1.5 text-[12.5px] text-gray-500"><Icon name="paperclip" size={13} />{row.files}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      );
    }

    /* ── KANBAN ─────────────────────────────────────────────────────── */
    function KanbanCard({ card, dark, onDragStart }) {
      const [done, total] = card.checklist;
      return (
        <div draggable onDragStart={e => onDragStart(e, card.id)}
          className="rounded-[14px] p-4 mb-3 cursor-grab active:cursor-grabbing transition-all hover:-translate-y-0.5"
          style={{ background: dark ? "#1F212C" : "#FFFFFF", boxShadow: "0 2px 8px rgba(20,20,43,0.06)" }}>
          <div className="flex items-start justify-between gap-2 mb-1.5">
            <p className={`text-[13.5px] font-semibold leading-snug ${dark ? "text-white" : "text-gray-900"}`}>{card.title}</p>
            <Icon name="more-horizontal" size={15} className="text-gray-400 shrink-0" />
          </div>
          <p className="text-[12px] text-gray-400 leading-snug mb-3 line-clamp-2">{card.desc}</p>
          <div className="flex items-center gap-2 mb-3">
            <div className="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
              <div className="h-full rounded-full bg-blue-500" style={{ width: `${total ? (done / total) * 100 : 0}%` }} />
            </div>
            <span className="text-[10.5px] text-gray-400 font-medium">{done}/{total}</span>
          </div>
          <div className="flex items-center justify-between">
            <AvatarStack ids={card.owners} />
            <div className="flex items-center gap-2.5 text-gray-400">
              <span className="flex items-center gap-1 text-[11px]"><Icon name="message-square" size={12} />{card.comments}</span>
              <span className="flex items-center gap-1 text-[11px]"><Icon name="paperclip" size={12} />{card.files}</span>
              <span className="flex items-center gap-1 text-[11px]"><Icon name="clock" size={12} />{card.time}</span>
            </div>
          </div>
        </div>
      );
    }

    function Kanban({ dark }) {
      const [cards, setCards] = useState(initialCards);
      const dragId = useRef(null);
      const onDragStart = (e, id) => { dragId.current = id; };
      const onDrop = (e, colKey) => { e.preventDefault(); setCards(cs => cs.map(c => c.id === dragId.current ? { ...c, col: colKey } : c)); };
      return (
        <div className="flex gap-5 overflow-x-auto pb-4" style={{ minHeight: "70vh" }}>
          {KANBAN_COLUMNS.map(col => {
            const colCards = cards.filter(c => c.col === col.key);
            return (
              <div key={col.key} onDragOver={e => e.preventDefault()} onDrop={e => onDrop(e, col.key)}
                className="w-[290px] shrink-0 rounded-2xl p-3.5" style={{ background: dark ? "#15171F" : "#F7F8FC" }}>
                <div className="flex items-center justify-between px-1.5 mb-3">
                  <div className="flex items-center gap-2">
                    <span className="w-2 h-2 rounded-full" style={{ background: col.color }} />
                    <span className={`text-[13px] font-semibold ${dark ? "text-white" : "text-gray-900"}`}>{col.label}</span>
                    <span className="text-[11px] text-gray-400 font-medium bg-gray-200/60 px-1.5 py-0.5 rounded-md">{colCards.length}</span>
                  </div>
                  <Icon name="plus" size={15} className="text-gray-400 cursor-pointer hover:text-blue-500 transition-colors" />
                </div>
                {colCards.map(card => <KanbanCard key={card.id} card={card} dark={dark} onDragStart={onDragStart} />)}
              </div>
            );
          })}
        </div>
      );
    }

    /* ── CRONOGRAMA (Gantt-style timeline) ──────────────────────────── */
    const GANTT_DATA = [
      { id: 1, name: "Redesign do site", owner: "AS", color: "#3B82F6", start: 5, duration: 25, progress: 62, status: "Working On It" },
      { id: 2, name: "App mobile - financeiro", owner: "CD", color: "#F59E0B", start: 0, duration: 18, progress: 24, status: "Stuck" },
      { id: 3, name: "Migração AWS", owner: "DA", color: "#7C3AED", start: 20, duration: 22, progress: 8, status: "Planning" },
      { id: 4, name: "Campanha Q3", owner: "BL", color: "#22C55E", start: 3, duration: 30, progress: 85, status: "Review" },
      { id: 5, name: "API pagamentos", owner: "AS", color: "#3B82F6", start: 0, duration: 35, progress: 100, status: "Done" },
      { id: 6, name: "Onboarding clientes", owner: "EN", color: "#EF4444", start: 30, duration: 12, progress: 0, status: "Waiting" },
      { id: 7, name: "Design system v2", owner: "BL", color: "#7C3AED", start: 10, duration: 20, progress: 45, status: "Working On It" },
      { id: 8, name: "Testes automatizados", owner: "DA", color: "#22C55E", start: 25, duration: 15, progress: 10, status: "Planning" },
    ];

    const GANTT_WEEKS = ["Sem 1", "Sem 2", "Sem 3", "Sem 4", "Sem 5", "Sem 6", "Sem 7", "Sem 8"];

    function Cronograma({ dark }) {
      const [hoveredRow, setHoveredRow] = useState(null);
      return (
        <div className="rounded-2xl overflow-hidden" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
          <div className="px-6 py-4 border-b flex items-center justify-between" style={{ borderColor: dark ? "#22242E" : "#F0F1F5" }}>
            <div className="flex items-center gap-2.5">
              <Icon name="calendar-clock" size={18} className="text-blue-500" />
              <h3 className={`font-semibold text-[15px] ${dark ? "text-white" : "text-gray-900"}`}>Cronograma do Projeto</h3>
            </div>
            <div className="flex items-center gap-2">
              {[
                { l: "Concluído", c: "#22C55E" }, { l: "Em andamento", c: "#3B82F6" },
                { l: "Atrasado", c: "#EF4444" }, { l: "Planejado", c: "#9CA3AF" },
              ].map(s => (
                <span key={s.l} className="flex items-center gap-1.5 text-[10px] font-medium text-gray-500">
                  <span className="w-2 h-2 rounded-full" style={{ background: s.c }} />{s.l}
                </span>
              ))}
            </div>
          </div>

          <div className="flex">
            {/* Left: task names */}
            <div className="w-[220px] shrink-0 border-r" style={{ borderColor: dark ? "#22242E" : "#F0F1F5" }}>
              <div className="h-10 px-4 flex items-center text-[10px] font-bold text-gray-400 uppercase tracking-widest" style={{ background: dark ? "#15171F" : "#FAFBFD" }}>Atividade</div>
              {GANTT_DATA.map((row, i) => (
                <div key={row.id} className="h-12 px-4 flex items-center gap-3 border-t transition-colors"
                  style={{ borderColor: dark ? "#22242E" : "#F3F4F7", background: hoveredRow === i ? (dark ? "#1F212C" : "#FAFBFD") : "transparent" }}
                  onMouseEnter={() => setHoveredRow(i)} onMouseLeave={() => setHoveredRow(null)}>
                  <span className="w-6 h-6 rounded-full text-[9px] font-bold text-white flex items-center justify-center shrink-0" style={{ background: row.color }}>{row.owner}</span>
                  <span className={`text-[12.5px] font-medium truncate ${dark ? "text-white" : "text-gray-900"}`}>{row.name}</span>
                </div>
              ))}
            </div>

            {/* Right: timeline bars */}
            <div className="flex-1 overflow-x-auto">
              <div className="flex" style={{ minWidth: "600px" }}>
                {GANTT_WEEKS.map((w, i) => (
                  <div key={w} className="flex-1 h-10 px-2 flex items-center text-[10px] font-bold text-gray-400 uppercase tracking-widest border-r border-b"
                    style={{ borderColor: dark ? "#22242E" : "#F0F1F5", background: dark ? "#15171F" : "#FAFBFD" }}>{w}</div>
                ))}
              </div>
              {GANTT_DATA.map((row, i) => {
                const barColor = row.progress === 100 ? "#22C55E" : row.progress > 50 ? "#3B82F6" : row.progress > 0 ? "#F59E0B" : "#9CA3AF";
                return (
                  <div key={row.id} className="relative h-12 flex border-t transition-colors"
                    style={{ borderColor: dark ? "#22242E" : "#F3F4F7", background: hoveredRow === i ? (dark ? "#1F212C" : "#FAFBFD") : "transparent" }}
                    onMouseEnter={() => setHoveredRow(i)} onMouseLeave={() => setHoveredRow(null)}>
                    {GANTT_WEEKS.map((_, wi) => (
                      <div key={wi} className="flex-1 border-r" style={{ borderColor: dark ? "#22242E" : "#F3F4F7" }} />
                    ))}
                    {/* Bar */}
                    <div className="absolute top-1/2 -translate-y-1/2 h-6 rounded-md flex items-center overflow-hidden"
                      style={{ left: `${(row.start / 56) * 100}%`, width: `${(row.duration / 56) * 100}%`, background: `${barColor}20`, border: `1px solid ${barColor}40` }}>
                      <div className="h-full rounded-md transition-all" style={{ width: `${row.progress}%`, background: barColor }} />
                      <span className="text-[9px] font-bold px-2 shrink-0" style={{ color: barColor }}>{row.progress}%</span>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      );
    }

    /* ── CALENDÁRIO EDITORIAL ───────────────────────────────────────── */
    const EDITORIAL_POSTS = [
      { date: "2026-07-02", title: "Post Instagram - Lançamento Q3", channel: "IG", status: "Done" },
      { date: "2026-07-02", title: "Artigo Blog - Tendências Tech", channel: "Blog", status: "Working On It" },
      { date: "2026-07-05", title: "Newsletter semanal", channel: "Email", status: "Planning" },
      { date: "2026-07-08", title: "Reel - Bastidores do projeto", channel: "IG", status: "Working On It" },
      { date: "2026-07-08", title: "Post LinkedIn - Case de sucesso", channel: "LI", status: "Done" },
      { date: "2026-07-10", title: "Story - Enquete produtos", channel: "IG", status: "Planning" },
      { date: "2026-07-12", title: "Artigo Blog - SEO avançado", channel: "Blog", status: "Planning" },
      { date: "2026-07-15", title: "Vídeo YouTube - Tutorial", channel: "YT", status: "Planning" },
      { date: "2026-07-15", title: "Post Facebook - Promoção", channel: "FB", status: "Planning" },
      { date: "2026-07-18", title: "Newsletter quinzenal", channel: "Email", status: "Planning" },
      { date: "2026-07-22", title: "Post Instagram - Dica rápida", channel: "IG", status: "Planning" },
      { date: "2026-07-25", title: "Artigo Blog - Review produto", channel: "Blog", status: "Planning" },
      { date: "2026-07-28", title: "Reel - Depoimento cliente", channel: "IG", status: "Planning" },
      { date: "2026-07-30", title: "Post LinkedIn - Vaga aberta", channel: "LI", status: "Planning" },
    ];

    const CHANNEL_COLORS = { IG: "#E1306C", Blog: "#1E293B", Email: "#3B82F6", LI: "#0A66C2", YT: "#EF4444", FB: "#1877F2" };
    const MONTHS_PT = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho","Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];

    function Calendario({ dark }) {
      const [calDate, setCalDate] = useState(new Date(2026, 6, 1)); // Jul 2026
      const [selectedDay, setSelectedDay] = useState(null);

      const y = calDate.getFullYear(), m = calDate.getMonth();
      const firstDay = new Date(y, m, 1).getDay();
      const daysInMonth = new Date(y, m + 1, 0).getDate();
      const daysInPrev = new Date(y, m, 0).getDate();
      const today = new Date().toISOString().split('T')[0];

      const days = [];
      for (let i = firstDay - 1; i >= 0; i--) days.push({ day: daysInPrev - i, other: true });
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const posts = EDITORIAL_POSTS.filter(p => p.date === dateStr);
        days.push({ day: d, date: dateStr, posts, isToday: dateStr === today });
      }
      const remaining = 42 - days.length;
      for (let d = 1; d <= remaining; d++) days.push({ day: d, other: true });

      const selectedPosts = selectedDay ? EDITORIAL_POSTS.filter(p => p.date === selectedDay) : [];

      return (
        <div className="flex gap-6">
          <div className="flex-1 rounded-2xl overflow-hidden" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
            {/* Header */}
            <div className="px-6 py-4 border-b flex items-center justify-between" style={{ borderColor: dark ? "#22242E" : "#F0F1F5" }}>
              <h3 className={`font-semibold text-[15px] ${dark ? "text-white" : "text-gray-900"}`}>{MONTHS_PT[m]} {y}</h3>
              <div className="flex items-center gap-2">
                <button onClick={() => setCalDate(new Date(y, m - 1, 1))}
                  className="p-2 rounded-lg hover:bg-gray-100 transition"><Icon name="chevron-left" size={16} className="text-gray-500" /></button>
                <button onClick={() => setCalDate(new Date())}
                  className="px-3 py-1.5 text-[11px] font-bold bg-gray-100 rounded-lg hover:bg-gray-200 transition">Hoje</button>
                <button onClick={() => setCalDate(new Date(y, m + 1, 1))}
                  className="p-2 rounded-lg hover:bg-gray-100 transition"><Icon name="chevron-right" size={16} className="text-gray-500" /></button>
              </div>
            </div>

            {/* Weekdays */}
            <div className="grid grid-cols-7 border-b" style={{ borderColor: dark ? "#22242E" : "#F0F1F5" }}>
              {["Dom","Seg","Ter","Qua","Qui","Sex","Sáb"].map(d => (
                <div key={d} className="py-2 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">{d}</div>
              ))}
            </div>

            {/* Days grid */}
            <div className="grid grid-cols-7">
              {days.map((d, i) => {
                const hasPosts = d.posts && d.posts.length > 0;
                const isSelected = selectedDay === d.date;
                return (
                  <div key={i} onClick={() => d.date && setSelectedDay(d.date)}
                    className={`min-h-[90px] p-2 border-b border-r cursor-pointer transition-all ${d.other ? 'opacity-30' : ''}`}
                    style={{
                      borderColor: dark ? "#22242E" : "#F0F1F5",
                      background: isSelected ? (dark ? "rgba(59,130,246,0.08)" : "#EFF4FF") : d.isToday ? (dark ? "rgba(239,68,68,0.06)" : "#FEF2F2") : "transparent",
                    }}>
                    <span className={`text-[11px] font-bold ${d.isToday ? 'text-red-500' : dark ? 'text-gray-400' : 'text-gray-600'}`}>{d.day}</span>
                    {hasPosts && (
                      <div className="mt-1 space-y-0.5">
                        {d.posts.slice(0, 3).map((p, pi) => (
                          <div key={pi} className="flex items-center gap-1">
                            <span className="w-1.5 h-1.5 rounded-full shrink-0" style={{ background: CHANNEL_COLORS[p.channel] || '#9CA3AF' }} />
                            <span className="text-[9px] font-medium text-gray-500 truncate">{p.title.split(' - ')[0]}</span>
                          </div>
                        ))}
                        {d.posts.length > 3 && <span className="text-[8px] text-gray-400 font-bold">+{d.posts.length - 3} mais</span>}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>

          {/* Sidebar: posts do dia */}
          <div className="w-[280px] shrink-0 rounded-2xl p-5" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
            <h3 className={`font-semibold text-[13px] uppercase tracking-widest mb-4 ${dark ? "text-white" : "text-gray-900"}`}>
              {selectedDay ? `Posts: ${selectedDay.split('-').reverse().join('/')}` : 'Selecione um dia'}
            </h3>
            {selectedPosts.length > 0 ? (
              <div className="space-y-3">
                {selectedPosts.map((p, i) => (
                  <div key={i} className="p-3 rounded-xl border transition-all hover:shadow-sm"
                    style={{ borderColor: dark ? "#22242E" : "#F0F1F5", background: dark ? "#15171F" : "#FAFBFD" }}>
                    <div className="flex items-center gap-2 mb-1.5">
                      <span className="px-2 py-0.5 rounded text-[8px] font-bold text-white" style={{ background: CHANNEL_COLORS[p.channel] || '#9CA3AF' }}>{p.channel}</span>
                      <span className="text-[9px] font-bold px-2 py-0.5 rounded-full"
                        style={{ background: STATUS_STYLES[p.status]?.bg, color: STATUS_STYLES[p.status]?.text }}>{p.status}</span>
                    </div>
                    <p className={`text-[12px] font-medium ${dark ? "text-white" : "text-gray-900"}`}>{p.title}</p>
                  </div>
                ))}
              </div>
            ) : (
              <p className="text-[11px] text-gray-400 italic text-center py-8">Nenhum post agendado.</p>
            )}
          </div>
        </div>
      );
    }

    /* ── APP ────────────────────────────────────────────────────────── */
    const TABS = [
      { key: "dashboard", label: "Dashboard" },
      { key: "boards", label: "Boards" },
      { key: "kanban", label: "Kanban" },
      { key: "cronograma", label: "Cronograma" },
      { key: "calendario", label: "Calendário" },
    ];
    const CRUMBS = {
      dashboard: ["Workspace", "Dashboard"],
      boards: ["Workspace", "Boards", "Lançamento Q3"],
      kanban: ["Workspace", "Kanban", "Sprint 14"],
      cronograma: ["Workspace", "Cronograma"],
      calendario: ["Workspace", "Calendário Editorial"],
    };

    function App() {
      const [active, setActive] = useState("dashboard");
      const [dark, setDark] = useState(false);
      useEffect(() => { if (window.lucide) window.lucide.createIcons(); });

      // Sidebar stats: count activities not "Conteúdo" and not "Done"
      const activeCount = initialRows.filter(r => r.status !== "Done").length;
      const doneCount = initialRows.filter(r => r.status === "Done").length;
      const totalCount = initialRows.length;
      const donePct = totalCount ? Math.round((doneCount / totalCount) * 100) : 0;

      return (
        <div style={{ background: dark ? "#0E0F14" : "#F7F8FC", minHeight: "100vh" }}>
          <Sidebar active={active} setActive={setActive} dark={dark} activeCount={activeCount} donePct={donePct} />
          <Header dark={dark} setDark={setDark} crumbs={CRUMBS[active] || CRUMBS.dashboard} />
          <main className="ml-[250px] pt-16 px-8 pb-10">
            <div className="pt-6 flex items-center justify-between">
              <div>
                <h1 className={`text-[22px] font-bold tracking-tight ${dark ? "text-white" : "text-gray-900"}`}>
                  {active === "dashboard" ? "Visão geral" : active === "boards" ? "Board — Lançamento Q3" : active === "kanban" ? "Kanban — Sprint 14" : active === "cronograma" ? "Cronograma do Projeto" : active === "calendario" ? "Calendário Editorial" : NAV_ITEMS.find(n => n.key === active)?.label}
                </h1>
                <p className="text-[13px] text-gray-400 mt-1">
                  {active === "dashboard" ? "Acompanhe o desempenho de todos os projetos em tempo real." : active === "boards" ? "Gerencie tarefas, prazos e responsáveis em formato de tabela." : active === "kanban" ? "Arraste os cards entre as colunas para atualizar o progresso." : active === "cronograma" ? "Visualize o progresso das atividades ao longo do tempo." : active === "calendario" ? "Publicações editoriais organizadas por data de postagem." : "Módulo em construção."}
                </p>
              </div>
              <div className="flex gap-1 p-1 rounded-full" style={{ background: dark ? "#1A1C25" : "#EEF0F5" }}>
                {TABS.map(t => (
                  <button key={t.key} onClick={() => setActive(t.key)}
                    className="px-4 py-1.5 rounded-full text-[12.5px] font-semibold transition-all"
                    style={{
                      background: active === t.key ? (dark ? "#2A2D3A" : "#FFFFFF") : "transparent",
                      color: active === t.key ? "#3B82F6" : "#9CA3AF",
                      boxShadow: active === t.key ? "0 2px 8px rgba(20,20,43,0.08)" : "none",
                    }}>
                    {t.label}
                  </button>
                ))}
              </div>
            </div>
            <div className="mt-6">
              {active === "dashboard" && <Dashboard dark={dark} />}
              {active === "boards" && <Boards dark={dark} />}
              {active === "kanban" && <Kanban dark={dark} />}
              {active === "cronograma" && <Cronograma dark={dark} />}
              {active === "calendario" && <Calendario dark={dark} />}
              {!["dashboard", "boards", "kanban", "cronograma", "calendario"].includes(active) && (
                <div className="rounded-2xl p-16 text-center" style={{ background: dark ? "#1A1C25" : "#FFFFFF", boxShadow: "0 2px 12px rgba(20,20,43,0.05)" }}>
                  <p className={`font-semibold text-[15px] ${dark ? "text-white" : "text-gray-900"}`}>Módulo "{NAV_ITEMS.find(n => n.key === active)?.label}" em construção</p>
                  <p className="text-[13px] text-gray-400 mt-1.5">Este módulo segue a mesma linguagem visual — posso detalhá-lo no próximo passo.</p>
                </div>
              )}
            </div>
          </main>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
